{
  "name": "media-bar",
  "layer": "top",
  "position": "top",
  "height": 34,
  "exclusive": true, // Tells the WM to push windows down
  "modules-center": ["custom/media"],
  "custom/media": {
    "exec": "playerctl metadata --format '{{ artist }} - {{ title }}'",
    "interval": 2,
    "format": "󰎈 {}",
    "on-click": "kitty -e cava",
    "on-click-right": "kitty -e cava"
  }
}
