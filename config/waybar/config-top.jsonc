{
  "name": "media-bar",
  "layer": "top",
  "position": "top",
  "height": 34,
  "exclusive": true, // Tells the WM to push windows down
  "modules-center": ["custom/media"],
  "custom/media": {
    "exec": "playerctl metadata --format '{{ artist }} - {{ title }}'",
    "interval": 2,
    "format": "󰎈 {}",
    "max-length": 50,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl play-pause"
  }
}
